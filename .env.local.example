# انسخ هذا الملف باسم .env.local وعبّي القيم بعد ما تنشئ مشروع Supabase
# شوف قسم "إعداد Supabase" بملف PROJECT_PLAN.md لمعرفة الجداول والـ storage bucket المطلوبين

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# مفتاح سري بصلاحية كاملة، يُستخدم فقط داخل لوحة التحكم على السيرفر
# خذه من Supabase: Project Settings > API > service_role secret
# لا تضع هذا المفتاح أبداً بأي كود يُعرض على المتصفح
SUPABASE_SERVICE_ROLE_KEY=

# إعدادات لوحة التحكم — لا تُشارك هذا الملف مع أحد ولا يُرفع على GitHub
# مسار سري للوحة التحكم (أرقام فقط، لا أحد يقدر يتوقعه)
ADMIN_ROUTE=
# رمز الدخول المكوّن من 6 أرقام
ADMIN_ACCESS_CODE=
# مفتاح عشوائي طويل يُستخدم لتوقيع جلسة الدخول (لا تغيّره بعد ما تحدده أول مرة)
ADMIN_SESSION_SECRET=
